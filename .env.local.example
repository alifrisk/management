# ============================================
# ALIF BANK — Risk Management Platform
# Файл с секретными ключами (НЕ загружать в GitHub!)
# ============================================

# Supabase — получить на https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://ТВОЙ_ПРОЕКТ.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=твой_anon_key_здесь

# Supabase Service Role Key (только для серверных операций)
SUPABASE_SERVICE_ROLE_KEY=твой_service_role_key_здесь

# Anthropic Claude API — получить на https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Email (Outlook SMTP) — для уведомлений
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=risk@alifbank.tj
SMTP_PASS=твой_пароль_outlook
SMTP_FROM=Risk Management Platform <risk@alifbank.tj>

# URL приложения
NEXT_PUBLIC_APP_URL=http://localhost:3000
